# Flask
FLASK_ENV=production
FLASK_SECRET_KEY=replace-with-a-long-random-secret-key

# AWS credentials (required — loaded only from .env, not ~/.aws/credentials)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Amazon Bedrock Knowledge Base (legacy — retained for reference; not used when uploadAccount is set)
BEDROCK_KNOWLEDGE_BASE_ID=your-knowledge-base-id
BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/amazon.titan-text-premier-v1:0

# uploadAccount — active AWS profile for Bedrock, S3, and DynamoDB
AWS_REGION_uploadAccount=eu-north-1
Knowledge_Base_ID_uploadAccount=your-knowledge-base-id
Data_Source_ID_uploadAccount=your-data-source-id
Bucket_Name_uploadAccount=your-s3-bucket-name
IAM_Role_ARN_uploadAccount=arn:aws:iam::ACCOUNT_ID:role/your-bedrock-kb-role

# DynamoDB — Most Common Questions (used with uploadAccount profile)
QUESTION_STATS_TABLE=QuestionStats

# Set to true for local/Docker UI testing without calling Bedrock
USE_MOCK_ANSWER=false

# IT Portal sign-in (password-based access at /it-login)
IT_PORTAL_PASSWORD=change-me

# Optional: application port (default 5000)
# PORT=5000
